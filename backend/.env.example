PORT=5000
NODE_ENV=development

MONGODB_URI=mongodb://localhost:27017/ai-health-report-analyzer
JWT_SECRET=replace-with-a-long-random-secret
SHARE_LINK_SECRET=replace-with-a-separate-share-secret

CLIENT_URL=http://localhost:5173
APP_URL=http://localhost:5173

LOG_LEVEL=info
REQUEST_BODY_LIMIT=1mb
UPLOAD_MAX_FILE_SIZE_BYTES=10485760
CREATE_INDEXES_ON_STARTUP=true

ENABLE_METRICS=false
METRICS_USERNAME=
METRICS_PASSWORD=

# AI provider options: openai, gemini, local
AI_PROVIDER=local
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GROQ_API_KEY=
GROQ_MODEL=llama3-70b-8192

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Redis and background jobs
REDIS_URL=redis://localhost:6379
REDIS_ENABLED=false
QUEUE_ENABLED=false
QUEUE_CONCURRENCY=2
ASYNC_REPORT_PROCESSING=false

# Optional security hooks
ENABLE_MALWARE_SCAN=false
ANTIVIRUS_SCAN_COMMAND=

# SMTP for password reset emails
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=AI Doctor <noreply@example.com>

# MongoDB connection tuning
MONGODB_MAX_RETRIES=10
MONGODB_RETRY_DELAY_MS=5000
MONGODB_MAX_POOL_SIZE=10
MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000
MONGODB_SOCKET_TIMEOUT_MS=45000
